{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2017",
    "lib": ["ES2017", "DOM"],
    "declaration": false,
    "outFile": "./dist/presence.js",
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["presence.ts"],
  "exclude": ["node_modules"]
}
